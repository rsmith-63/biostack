{
  "name": "biostack",
  "version": "1.0.0",
  "description": "Bio-Research React-Koa Scaffold",
  "type": "module",
  "scripts": {
    "dev:server": "node src/server/index.js",
    "dev:client": "vite src/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build src/client",
    "serve": "vite preview src/client",
    "start": "node src/server/index.js",
    "start_mcp": "node src/server/index.js",
    "test:client": "vitest -c src/client/vite.config.js",
    "test:server": "vitest -c vitest.config.server.js",
    "test": "npm run test:client -- --run && npm run test:server -- --run",
    "test:watch": "concurrently \"npm run test:client\" \"npm run test:server\"",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^16.4.5",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-mount": "^4.0.0",
    "koa-router": "^13.0.1",
    "koa-static": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "supertest": "^7.2.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
